---
import { getBrandById, getSetsByBrandId } from "../../content";
import Set from "../sets/set.compact.astro";

const { id } = Astro.props;
const brand = await getBrandById(id);
if (!brand) return Astro.redirect("/404");
const { name, description_i18n } = brand.data;

const sets = await getSetsByBrandId(brand.id);
---

<div>
  <h2>{name}</h2>
  <div>
    {description_i18n.en}
  </div>
  <div>
    <h3>Sets</h3>
    {sets.map((set) => <Set id={set.id} />)}
  </div>
</div>
