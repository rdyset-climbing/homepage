---
import { getString } from "../../content";
const { currency: defaultCurrency, price } = Astro.props;
const disclaimer = getString("set.price.disclaimer", { locale: Astro.currentLocale }).t;
---

<price-display
  data-price={price}
  data-default-currency={defaultCurrency || "JPY"}
  title={disclaimer}></price-display>

<script>
  const STORAGE_KEY = "currency";

  const ratios: Record<string, number> = {
    JPY: 1,
    EUR: 0.0054,
    USD: 0.0062,
  };
  const symbols: Record<string, string> = {
    JPY: "¥",
    EUR: "€",
    USD: "$",
  };
  const symbols2: Record<string, string> = {
    JPY: "約",
    EUR: "≈",
    USD: "~",
  };

  class PriceDisplay extends HTMLElement {
    connectedCallback() {
      this.render();
      window.addEventListener("currencychange", () => this.render());
    }

    render() {
      const price = Number(this.dataset.price);
      const defaultCurrency = this.dataset.defaultCurrency || "JPY";
      const currency = localStorage.getItem(STORAGE_KEY) || defaultCurrency;
      const converted = Math.round(price * ratios[currency]);
      const formatted = new Intl.NumberFormat().format(converted);
      let priceFormatted;
      if (["JPY", "EUR"].includes(currency)) {
        priceFormatted = `${formatted}${symbols[currency]}`;
      } else {
        priceFormatted = `${symbols[currency]}${formatted}`;
      }
      this.textContent = `${symbols2[currency]}${priceFormatted}`;
    }
  }

  if (!customElements.get("price-display")) {
    customElements.define("price-display", PriceDisplay);
  }
</script>

<style>
  price-display {
    font-size: 1.4rem;
    opacity: 0.5;
  }
</style>
