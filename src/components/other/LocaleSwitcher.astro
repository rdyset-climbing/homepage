---
const locales = [
  { code: "en", label: "EN", currency: "USD" },
  { code: "fr", label: "FR", currency: "EUR" },
  { code: "ja", label: "日本語", currency: "JPY" },
];
---

<div class="locale-switcher">
  {
    locales.map(({ code, label, currency }) => (
      <button
        class="locale-btn currency-btn"
        data-currency={currency}
        data-locale={code}
      >
        {label}
      </button>
    ))
  }
</div>

<script>
  // currency
  const STORAGE_KEY = "currency";

  function updateCurrencyButtons(active: string) {
    document
      .querySelectorAll<HTMLButtonElement>(".currency-btn")
      .forEach((btn) => {
        btn.classList.toggle("active", btn.dataset.currency === active);
      });
  }

  // locale
  const locales = ["en", "fr", "ja"];

  function currentLocale(): string {
    const segment = window.location.pathname.split("/")[1];
    return locales.includes(segment) ? segment : "en";
  }

  function localePath(locale: string): string {
    const parts = window.location.pathname.split("/");
    parts[1] = locale;
    return parts.join("/") || "/";
  }

  function updateLocaleButtons(active: string) {
    document
      .querySelectorAll<HTMLButtonElement>(".locale-btn")
      .forEach((btn) => {
        btn.classList.toggle("active", btn.dataset.locale === active);
      });
  }

  function init() {
    updateLocaleButtons(currentLocale());

    document
      .querySelectorAll<HTMLButtonElement>(".locale-btn")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          window.location.href = localePath(btn.dataset.locale!);
        });
      });

    const stored = localStorage.getItem(STORAGE_KEY) || "JPY";
    updateCurrencyButtons(stored);

    document
      .querySelectorAll<HTMLButtonElement>(".currency-btn")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const currency = btn.dataset.currency!;
          localStorage.setItem(STORAGE_KEY, currency);
          updateCurrencyButtons(currency);
          window.dispatchEvent(
            new CustomEvent("currencychange", { detail: currency }),
          );
        });
      });
  }

  init();
</script>

<style>
  .locale-switcher {
    display: flex;
    gap: 4px;
  }
  .locale-btn {
    border: 1px solid #333;
    background: none;
    padding: 4px 8px;
    cursor: pointer;
    font-size: 0.85rem;
    font-family: inherit;
    opacity: 0.4;

    &.active {
      background: #333;
      color: white;
      opacity: 1;
    }

    &:hover:not(.active) {
      opacity: 0.8;
    }
  }
</style>
