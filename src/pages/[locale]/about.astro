---
import type { GetStaticPaths } from "astro";
import { getString } from "../../content";
import Layout from "../../layouts/Layout.astro";
import AboutContent from "../../components/about/AboutContent.astro";

export const getStaticPaths = (() => {
  return [
    { params: { locale: "en" } },
    { params: { locale: "fr" } },
    { params: { locale: "ja" } },
  ];
}) satisfies GetStaticPaths;
---

<Layout title={getString("about", { locale: Astro.currentLocale })?.t}>
  <AboutContent />
</Layout>
