---
import { getBrandById, getSetsByBrandId } from "../../content";
import Set from "../sets/Set.compact.astro";

const { id } = Astro.props;
const brand = await getBrandById(id);
if (!brand) return Astro.redirect("/404");
const { name, description_i18n, url, instagram } = brand.data;

const sets = await getSetsByBrandId(brand.id);
---

<div class="brand-layout">
  <div class="brand-side">
    <div class="brand-infos">
      <h2 class="brand-name">{name}</h2>
      <a class="brand-url" href={url}>{url}</a>
      <a class="brand-instagram" href={instagram}>{instagram}</a>
      <div>
        {description_i18n.en}
      </div>
    </div>
  </div>
  <div class="brand-sets">
    {sets.map((set) => <Set id={set.id} />)}
  </div>
</div>

<style>
  .brand-layout {
    display: grid;
    grid-template-columns: 301px 1fr;
    padding: var(--spacing);
    gap: var(--spacing);

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      padding: var(--halfSpacing);
    }
  }
  .brand-side {
    position: relative;
  }
  .brand-infos {
    position: sticky;
    top: var(--spacing);
    background-color: white;
    /* border: 1px solid #333; */
  }
  .brand-name {
    font-size: 4rem;

    @media (max-width: 768px) {
      font-size: 2.5rem;
    }
  }
  .brand-sets {
    display: flex;
    flex-direction: column;
    gap: var(--spacing);
    background-color: white;
  }
</style>
