---
import type { GetStaticPaths, InferGetStaticParamsType } from "astro";
import { getBrands, getBrandBySlug } from "../../content";
import { idToSlug } from "../../helpers";
import Layout from "../../layouts/Layout.astro";
import Brand from "../../components/brands/brand.astro";

export const getStaticPaths = (async () => {
  const brands = await getBrands();
  return brands.map((brand) => ({ params: { id: idToSlug(brand.id) } }));
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;

const { id: slug } = Astro.params as Params;
const brand = await getBrandBySlug(slug);
if (!brand) return Astro.redirect("/404");
const { name } = brand.data;
const { id } = brand;
---

<Layout title={name ?? id}>
  <Brand id={id} />
</Layout>
