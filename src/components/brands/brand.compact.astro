---
import { Image } from "astro:assets";
import {
  getAllSetImages,
  getBrandById,
  getBrandPath,
  getBrandPhoto,
} from "../../content";

const { id } = Astro.props;
const brand = await getBrandById(id);
if (!brand) return Astro.redirect("/404");
const { name, url } = brand.data;

const image = getBrandPhoto(brand);
console.log(image);
---

<div>
  <h2><a href={getBrandPath(brand)}>{name}</a></h2>
  {image && <Image width={400} alt={name} src={image} />}
  <p><a href={url}>{url}</a></p>
  <hr />
</div>
