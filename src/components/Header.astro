---
import Currency from "./other/Currency.astro";
// const nav = ["about", "brands"];
const nav = ["about"];
---

<div class="header">
  <div class="header-left">
    <h1><a href="/"><img src="/images/readyset_1.svg" alt="ReadySet" /></a></h1>
  </div>
  <nav class="header-right">
    <Currency />
    <ul>
      {
        nav.map((item) => (
          <li>
            <a href={`/${item}`}>{item}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<style>
  .header {
    background: white;
    padding: var(--halfSpacing);
    display: flex;
    justify-content: space-between;
  }
  .header-left {
    display: flex;
    gap: 5px;
    flex-direction: column;
    /* align-items: flex-end; */
  }
  h1 {
    width: 200px;
    img {
      display: block;
    }
  }
  nav {
    display: flex;
    align-items: center;
    ul {
      padding: 0;
      margin: 0;
      list-style-type: none;
      display: flex;
      gap: var(--halfSpacing);
      align-items: center;
      justify-content: center;
      text-transform: uppercase;
    }
  }
</style>
